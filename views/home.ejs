<h2 class="h5 mb-3 mt-2">Día Anterior</h2>


<div class="row g-3 row-cols-1 row-cols-sm-2 row-cols-lg-5">
  <% if (kpis && kpis.length) { %>
    <% kpis.forEach(k => { %>
      <div class="col">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted small mb-1">
              <%= k.label %>
            </div>
            <div class="display-6 fw-semibold"><%= k.value %></div>
            <% if (k.campoLine) { %>
            <div class="small text-body-secondary mt-2 fw-bold"><%= k.campoLine %></div>
            <% } else if (k.key !== 'pctRespuestas' && k.key !== 'pctOk') { %>
            <div class="badge <%= k.badgeClass %> mt-2"><%= k.deltaText %></div>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-12">
      <div class="alert alert-warning">No hay datos para mostrar.</div>
    </div>
  <% } %>
</div>

<hr class="my-4">

<div class="row g-4">
  <!-- Columna izquierda -->
  <div class="col-12 col-lg-6">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <h2 class="h5 mb-0">Mensajería <span class="text-body-secondary fw-normal" id="lbl-subtitulo-vista">por día</span></h2>
        <div class="btn-group btn-group-sm" role="group" aria-label="Vista tabla">
          <button type="button" class="btn btn-outline-secondary active" data-vista="diario">Diario</button>
          <button type="button" class="btn btn-outline-secondary" data-vista="mensual">Mensual</button>
        </div>
      </div>

      <div class="d-flex flex-wrap align-items-center gap-2">
        <div class="btn-group btn-group-sm" role="group" aria-label="Filtro motivo">
          <button type="button" class="btn btn-outline-secondary active" data-motivo="total">Total</button>
          <button type="button" class="btn btn-outline-secondary" data-motivo="_1p">_1p</button>
          <button type="button" class="btn btn-outline-secondary" data-motivo="_2p">_2p</button>
          <button type="button" class="btn btn-outline-secondary" data-motivo="_3p">_3p</button>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-ultimos7-excel" disabled>Excel</button>
      </div>
    </div>

    <div class="row g-2 align-items-end mb-2" id="row-filtros-diario">
      <div class="col-auto">
        <label for="fecha-desde" class="form-label small text-body-secondary mb-0">Desde</label>
        <input type="date" class="form-control form-control-sm" id="fecha-desde" autocomplete="off">
      </div>
      <div class="col-auto">
        <label for="fecha-hasta" class="form-label small text-body-secondary mb-0">Hasta</label>
        <input type="date" class="form-control form-control-sm" id="fecha-hasta" autocomplete="off">
      </div>
      <div class="col-auto d-flex align-items-end">
        <button type="button" class="btn btn-dark btn-sm" id="btn-ultimos7-aplicar">Aplicar</button>
      </div>
    </div>
    <div class="small text-danger mb-2 d-none" id="ultimos7-fecha-error" role="alert"></div>

    <div class="table-responsive border rounded-4" id="wrap-tabla-diario">
      <table class="table table-hover align-middle mb-0" id="tabla-ultimos7">
        <thead class="table-light">
          <tr>
            <th>Fecha</th>
            <th class="text-end">Enviados</th>
            <th class="text-end">Prom. RefUtil</th>
            <th class="text-end">Prom. RefUtil Bloq</th>
            <th class="text-end">OK</th>
            <th class="text-end">Mal</th>
          </tr>
        </thead>
        <tbody>
          <tr><td colspan="6" class="text-center py-4 text-body-secondary">Cargando…</td></tr>
        </tbody>
      </table>
    </div>

    <div class="table-responsive border rounded-4 d-none" id="wrap-tabla-mensual">
      <table class="table table-hover align-middle mb-0" id="tabla-mensual">
        <thead class="table-light">
          <tr>
            <th>Mes</th>
            <th class="text-end">Enviados</th>
            <th class="text-end">Prom. RefUtil</th>
            <th class="text-end">Prom. RefUtil Bloq</th>
            <th class="text-end">OK</th>
            <th class="text-end">Mal</th>
          </tr>
        </thead>
        <tbody>
          <tr><td colspan="6" class="text-center py-4 text-body-secondary">Cargando…</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Columna derecha: gráfico mixto -->
  <div class="col-12 col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h3 class="h6 mb-0">Mensajería — <span id="lbl-dias-chart">10</span> <span id="lbl-dias-chart-suffix">días</span></h3>
          <!-- opcional: se sincroniza con los mismos botones de motivo -->
        </div>
        <canvas id="mensajeriaChart" height="140"></canvas>
        <div class="small text-body-secondary mt-2">
          Área: enviados (izq). Barras apiladas: OK / Mal (izq). Líneas: %Respuestas y %OK (der).
        </div>
      </div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js" crossorigin="anonymous"></script>
<script>
(function () {
   const BASE = window.BASE_PATH || "";

  const MESES_LARGOS = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];

  /** fecha = primer día del mes (YYYY-MM-DD desde API). */
  function formatMesEspañolLargo(fechaRaw) {
    const s = (fechaRaw || '').toString().slice(0, 10);
    const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(s);
    if (!m) return s;
    const y = Number(m[1]);
    const mo = Number(m[2]);
    if (mo < 1 || mo > 12) return s;
    return `${MESES_LARGOS[mo - 1]} ${y}`;
  }

  const $tableBody = document.querySelector('#tabla-ultimos7 tbody');
  const $tableBodyMensual = document.querySelector('#tabla-mensual tbody');
  const $btns = document.querySelectorAll('[data-motivo]');
  const $btnsVista = document.querySelectorAll('[data-vista]');
  const $desde = document.getElementById('fecha-desde');
  const $hasta = document.getElementById('fecha-hasta');
  const $btnAplicar = document.getElementById('btn-ultimos7-aplicar');
  const $btnExcel = document.getElementById('btn-ultimos7-excel');
  const $err = document.getElementById('ultimos7-fecha-error');
  const $rowFiltrosDiario = document.getElementById('row-filtros-diario');
  const $wrapTablaDiario = document.getElementById('wrap-tabla-diario');
  const $wrapTablaMensual = document.getElementById('wrap-tabla-mensual');
  const $lblSubtituloVista = document.getElementById('lbl-subtitulo-vista');

  // --- Config ---
  const ENABLE_HEATMAP = false;    // dejalo en false por ahora (texto plano)

  const lblDias = document.getElementById('lbl-dias');
  const lblDiasChart = document.getElementById('lbl-dias-chart');
  const lblDiasChartSuffix = document.getElementById('lbl-dias-chart-suffix');

  let viewMode = 'diario';
  let lastRows = [];
  let lastRowsMensual = [];
  let lastMotivo = 'total';
  let lastDesde = '';
  let lastHasta = '';

  function setVistaActive(target) {
    $btnsVista.forEach(b => b.classList.toggle('active', b === target));
  }

  function applyViewLayout() {
    const diario = viewMode === 'diario';
    if ($lblSubtituloVista) $lblSubtituloVista.textContent = diario ? 'por día' : 'por mes';
    $rowFiltrosDiario?.classList.toggle('d-none', !diario);
    $wrapTablaDiario?.classList.toggle('d-none', !diario);
    $wrapTablaMensual?.classList.toggle('d-none', diario);
  }

  function toLocalISODate(d) {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  /** Por defecto: 10 días con último día = ayer (local), alineado al SP con AsOfDate null y dias=10. */
  function setDefaultDateRange() {
    const hasta = new Date();
    hasta.setHours(0, 0, 0, 0);
    hasta.setDate(hasta.getDate() - 1);
    const desde = new Date(hasta);
    desde.setDate(desde.getDate() - 9);
    $desde.value = toLocalISODate(desde);
    $hasta.value = toLocalISODate(hasta);
  }

  function hideError() {
    $err.classList.add('d-none');
    $err.textContent = '';
  }

  function showError(msg) {
    $err.textContent = msg;
    $err.classList.remove('d-none');
  }

  function inclusiveDayCount(desdeStr, hastaStr) {
    const a = new Date(desdeStr + 'T12:00:00');
    const b = new Date(hastaStr + 'T12:00:00');
    return Math.round((b - a) / 86400000) + 1;
  }

  function getActiveMotivo() {
    const active = document.querySelector('[data-motivo].active');
    return active?.dataset?.motivo || 'total';
  }

  function updateChartLabels(desdeStr, hastaStr) {
    const n = inclusiveDayCount(desdeStr, hastaStr);
    if (lblDias) lblDias.textContent = String(n);
    if (lblDiasChart) lblDiasChart.textContent = String(n);
    if (lblDiasChartSuffix) lblDiasChartSuffix.textContent = n === 1 ? 'día' : 'días';
  }

  function updateChartLabelsMensual(count) {
    const n = Math.max(0, Number(count) || 0);
    if (lblDias) lblDias.textContent = String(n);
    if (lblDiasChart) lblDiasChart.textContent = String(n);
    if (lblDiasChartSuffix) lblDiasChartSuffix.textContent = n === 1 ? 'mes' : 'meses';
  }

  // --- Utilidades ---
  function setActive(target) { $btns.forEach(b => b.classList.toggle('active', b === target)); }
  function formatNum(n) { return Number(n || 0).toLocaleString('es-AR'); }

  // Heatmap (apagado si ENABLE_HEATMAP=false)
  const THRESH1 = 0.01, THRESH2 = 0.05;
  function heatClass(value, avg) {
    if (!ENABLE_HEATMAP) return "";
    const v = Number(value), a = Number(avg);
    if (!isFinite(v) || !isFinite(a)) return "";
    if (a === 0) return v > 0 ? "heat-pos-2" : "";
    const pct = (v - a) / a;
    if (Math.abs(pct) < THRESH1) return "";
    return (Math.abs(pct) > THRESH2)
      ? (pct > 0 ? "heat-pos-2" : "heat-neg-2")
      : (pct > 0 ? "heat-pos-1" : "heat-neg-1");
  }

  // --- Chart.js ---
  const ctx = document.getElementById('mensajeriaChart')?.getContext('2d');
  let chart = null;

  /**
   * @param {object[]} rows filas API (diario o mensual; misma forma numérica)
   * @param {boolean} monthly si true, eje X = mes en español (Febrero 2026, …)
   */
  function buildChart(rows, monthly = false) {
    if (!ctx) return;

    const dataAsc = [...rows].sort((a, b) => new Date(a.fecha) - new Date(b.fecha));

    const labels = dataAsc.map(r =>
      monthly ? formatMesEspañolLargo(r.fecha) : (r.fecha || '').toString().slice(0, 10));
    const enviados = dataAsc.map(r => Number(r.enviados || 0));
    const ok = dataAsc.map(r => Number(r.ok || 0));
    const mal = dataAsc.map(r => Number(r.mal || 0));
    const pctRespuestas = dataAsc.map(r => Number(r.pctRespuestas || 0));
    const pctOk = dataAsc.map(r => Number(r.pctOk || 0));

    const barTopRadius = 6;
    /** Redondeo superior solo en el tramo que cierra la pila ok+mal (misma idea que cierres.ejs). */
    function mensajeriaStackedBarTopRadius(ctx) {
      const i = ctx.dataIndex;
      const okVal = Number(ok[i] || 0);
      const malVal = Number(mal[i] || 0);
      const label = ctx.dataset.label;
      const r = barTopRadius;
      const top = { topLeft: r, topRight: r, bottomLeft: 0, bottomRight: 0 };
      if (label === 'mal' && malVal > 0) return top;
      if (label === 'ok' && malVal <= 0 && okVal > 0) return top;
      return 0;
    }

    if (chart) chart.destroy();

    chart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [
  // Área (enviados) - eje izquierdo
  {
    type: 'line',
    label: 'enviados',
    data: enviados,
    yAxisID: 'y',
    tension: 0.3,
    fill: true,
    borderColor: 'rgba(13,110,253,0.8)',   // azul bootstrap-ish
    backgroundColor: 'rgba(13,110,253,0.12)', // área más clara
    pointRadius: 0,
    order: 3
  },
  // Barras apiladas: OK (verde) y Mal (rojo) - eje izquierdo
  {
    type: 'bar',
    label: 'ok',
    data: ok,
    yAxisID: 'y',
    stack: 'estado',
    backgroundColor: '#198754',  // verde
    borderColor: '#198754',
    borderWidth: 0,
    borderRadius: mensajeriaStackedBarTopRadius,
    order: 2
  },
  {
    type: 'bar',
    label: 'mal',
    data: mal,
    yAxisID: 'y',
    stack: 'estado',
    backgroundColor: '#dc3545',  // rojo
    borderColor: '#dc3545',
    borderWidth: 0,
    borderRadius: mensajeriaStackedBarTopRadius,
    order: 2
  },
  // Líneas de % - eje derecho
  {
    type: 'line',
    label: '%Respuestas',
    data: pctRespuestas,
    yAxisID: 'y1',
    tension: 0.3,
    pointRadius: 3,
    borderWidth: 2,
    borderColor: '#6f42c1',      // violeta
    backgroundColor: '#6f42c1',
    fill: false,
    order: 1
  },
  {
    type: 'line',
    label: '%OK',
    data: pctOk,
    yAxisID: 'y1',
    tension: 0.3,
    pointRadius: 3,
    borderWidth: 2,
    borderColor: '#198754',      // verde (igual que barras OK)
    backgroundColor: '#198754',
    fill: false,
    order: 1
  },
]

      },
      options: {
        responsive: true,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { position: 'top' },
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const isPct = ctx.dataset.yAxisID === 'y1';
                const v = ctx.parsed.y;
                return `${ctx.dataset.label}: ${isPct ? (v?.toFixed?.(1) + '%') : v?.toLocaleString?.('es-AR')}`;
              }
            }
          }
        },
        scales: {
          x: {
            ticks: monthly
              ? { maxRotation: 45, minRotation: 24, autoSkip: true, maxTicksLimit: 14 }
              : {},
          },
          y: { position: 'left', title: { display: true, text: 'Cantidad' }, beginAtZero: true },
          y1:{ position: 'right', title: { display: true, text: '%' }, beginAtZero: true, suggestedMax: 100, grid: { drawOnChartArea: false } }
        }
      }
    });
  }

  function pctOneDecimal(v) {
    return Math.round(Number(v || 0) * 10) / 10;
  }

  function downloadExcel() {
    if (typeof XLSX === 'undefined') return;
    if (viewMode === 'mensual') {
      if (!lastRowsMensual.length) return;
      const sorted = [...lastRowsMensual].sort((a, b) => new Date(a.fecha) - new Date(b.fecha));
      const rows = sorted.map(r => ({
        Mes: formatMesEspañolLargo(r.fecha),
        Enviados: Number(r.enviados || 0),
        'Prom. RefUtil': Number(r.prom_RefUtil || 0),
        'Prom. RefUtil Bloq': Number(r.prom_RefUtilBloqueante || 0),
        OK: Number(r.ok || 0),
        Mal: Number(r.mal || 0),
        '%Respuestas': pctOneDecimal(r.pctRespuestas),
        '%OK': pctOneDecimal(r.pctOk),
      }));
      const ws = XLSX.utils.json_to_sheet(rows);
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, 'Mensajeria_mensual');
      const stamp = new Date().toISOString().slice(0, 10);
      XLSX.writeFile(wb, `mensajeria_mensual_${lastMotivo}_${stamp}.xlsx`);
      return;
    }
    if (!lastRows.length) return;
    const sorted = [...lastRows].sort((a, b) => new Date(a.fecha) - new Date(b.fecha));
    const rows = sorted.map(r => ({
      Fecha: (r.fecha || '').toString().slice(0, 10),
      Enviados: Number(r.enviados || 0),
      'Prom. RefUtil': Number(r.prom_RefUtil || 0),
      'Prom. RefUtil Bloq': Number(r.prom_RefUtilBloqueante || 0),
      OK: Number(r.ok || 0),
      Mal: Number(r.mal || 0),
      '%Respuestas': pctOneDecimal(r.pctRespuestas),
      '%OK': pctOneDecimal(r.pctOk),
    }));
    const ws = XLSX.utils.json_to_sheet(rows);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Mensajeria');
    const name = `mensajeria_${lastMotivo}_${lastDesde}_${lastHasta}.xlsx`;
    XLSX.writeFile(wb, name);
  }

  async function loadMensual(motivo = 'total') {
    hideError();
    $btnExcel.disabled = true;
    lastRowsMensual = [];
    if (!$tableBodyMensual) return;
    $tableBodyMensual.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-body-secondary">Cargando…</td></tr>';
    try {
      const q = new URLSearchParams({ motivo });
      const res = await fetch(`${BASE}/api/envio-mensual?${q}`, { cache: 'no-store' });
      const payload = await res.json();
      if (!payload.ok) throw new Error(payload.error || `Error ${res.status}`);

      const { data, avg } = payload;
      lastMotivo = motivo;
      lastRowsMensual = data || [];
      $btnExcel.disabled = !lastRowsMensual.length;

      if (!data?.length) {
        $tableBodyMensual.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-body-secondary">Sin datos.</td></tr>';
        updateChartLabelsMensual(0);
        buildChart([], true);
        return;
      }

      updateChartLabelsMensual(data.length);

      const A = {
        enviados: avg?.AvgEnviados ?? 0,
        promRU:   avg?.AvgProm_RefUtil ?? 0,
        promRUB:  avg?.AvgProm_RefUtilBloq ?? 0,
        ok:       avg?.AvgOk ?? 0,
        mal:      avg?.AvgMal ?? 0
      };

      $tableBodyMensual.innerHTML = data.map(r => {
        const c1 = heatClass(r.enviados,               A.enviados);
        const c2 = heatClass(r.prom_RefUtil,           A.promRU);
        const c3 = heatClass(r.prom_RefUtilBloqueante, A.promRUB);
        const c4 = heatClass(r.ok,                     A.ok);
        const c5 = heatClass(r.mal,                    A.mal);
        const mesLabel = formatMesEspañolLargo(r.fecha);
        return `
          <tr>
            <td>${mesLabel}</td>
            <td class="text-end ${c1}">${formatNum(r.enviados)}</td>
            <td class="text-end ${c2}">${formatNum(r.prom_RefUtil)}</td>
            <td class="text-end ${c3}">${formatNum(r.prom_RefUtilBloqueante)}</td>
            <td class="text-end ${c4}">${formatNum(r.ok)}</td>
            <td class="text-end ${c5}">${formatNum(r.mal)}</td>
          </tr>
        `;
      }).join('');

      buildChart(data, true);
    } catch (err) {
      console.error(err);
      showError(err.message || 'Error al cargar datos mensuales.');
      $tableBodyMensual.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-danger">Error al cargar datos.</td></tr>';
      $btnExcel.disabled = true;
      lastRowsMensual = [];
      updateChartLabelsMensual(0);
      buildChart([], true);
    }
  }

  // --- Carga tabla + gráfico (misma fuente de datos /api/ultimos7) ---
  async function load(motivo = 'total') {
    const desdeStr = ($desde?.value || '').trim();
    const hastaStr = ($hasta?.value || '').trim();
    hideError();

    if (!desdeStr || !hastaStr) {
      showError('Elegí fecha desde y hasta.');
      return;
    }
    if (desdeStr > hastaStr) {
      showError('La fecha hasta no puede ser anterior a desde.');
      return;
    }
    const span = inclusiveDayCount(desdeStr, hastaStr);
    if (span > 60) {
      showError('El rango máximo es 60 días inclusive.');
      return;
    }

    updateChartLabels(desdeStr, hastaStr);
    $btnExcel.disabled = true;
    lastRows = [];

    $tableBody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-body-secondary">Cargando…</td></tr>';
    try {
      const q = new URLSearchParams({
        motivo,
        desde: desdeStr,
        hasta: hastaStr,
      });
      const res = await fetch(`${BASE}/api/ultimos7?${q}`, { cache: "no-store" });
      const payload = await res.json();
      if (!payload.ok) throw new Error(payload.error || `Error ${res.status}`);

      const { data, avg } = payload;

      lastMotivo = motivo;
      lastDesde = desdeStr;
      lastHasta = hastaStr;
      lastRows = data || [];
      $btnExcel.disabled = !lastRows.length;

      // Render tabla
      if (!data?.length) {
        $tableBody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-body-secondary">Sin datos.</td></tr>';
      } else {
        const A = {
          enviados: avg?.AvgEnviados ?? 0,
          promRU:   avg?.AvgProm_RefUtil ?? 0,
          promRUB:  avg?.AvgProm_RefUtilBloq ?? 0,
          ok:       avg?.AvgOk ?? 0,
          mal:      avg?.AvgMal ?? 0
        };

        $tableBody.innerHTML = data.map(r => {
          const c1 = heatClass(r.enviados,               A.enviados);
          const c2 = heatClass(r.prom_RefUtil,           A.promRU);
          const c3 = heatClass(r.prom_RefUtilBloqueante, A.promRUB);
          const c4 = heatClass(r.ok,                     A.ok);
          const c5 = heatClass(r.mal,                    A.mal);
          const fecha = (r.fecha || '').toString().slice(0,10);

          return `
            <tr>
              <td>${fecha}</td>
              <td class="text-end ${c1}">${formatNum(r.enviados)}</td>
              <td class="text-end ${c2}">${formatNum(r.prom_RefUtil)}</td>
              <td class="text-end ${c3}">${formatNum(r.prom_RefUtilBloqueante)}</td>
              <td class="text-end ${c4}">${formatNum(r.ok)}</td>
              <td class="text-end ${c5}">${formatNum(r.mal)}</td>
            </tr>
          `;
        }).join('');
      }

      buildChart(data || []);
    } catch (err) {
      console.error(err);
      showError(err.message || 'Error al cargar datos.');
      $tableBody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-danger">Error al cargar datos.</td></tr>';
      buildChart([]);
      $btnExcel.disabled = true;
      lastRows = [];
    }
  }

  $btns.forEach(btn => btn.addEventListener('click', () => {
    setActive(btn);
    if (viewMode === 'mensual') loadMensual(btn.dataset.motivo);
    else load(btn.dataset.motivo);
  }));

  $btnsVista.forEach(btn => btn.addEventListener('click', () => {
    const v = btn.dataset.vista;
    if (!v || v === viewMode) return;
    viewMode = v;
    setVistaActive(btn);
    applyViewLayout();
    hideError();
    if (viewMode === 'mensual') {
      $btnExcel.disabled = true;
      loadMensual(getActiveMotivo());
    } else {
      load(getActiveMotivo());
    }
  }));

  $btnAplicar?.addEventListener('click', () => { if (viewMode === 'diario') load(getActiveMotivo()); });
  $btnExcel?.addEventListener('click', downloadExcel);

  applyViewLayout();
  setDefaultDateRange();
  load('total');
})();
</script>
